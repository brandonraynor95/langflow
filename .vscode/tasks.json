{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Init",
      "type": "shell",
      "command": "make init"
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "make backend"
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "make frontend"
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "make unit_tests",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "make lint"
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "make format"
    },
    {
      "label": "Install",
      "type": "shell",
      "command": "make install_backend && make install_frontend"
    },
    {
      "label": "Install Backend",
      "type": "shell",
      "command": "make install_backend EXTRA_ARGS='--extra audio'"
    }
  ]
}
